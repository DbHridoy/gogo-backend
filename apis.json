[
  {
    "module": "Auth",
    "basePath": "/auth",
    "routes": [
      {
        "method": "POST",
        "path": "/register",
        "handler": "authController.register",
        "auth": "Public",
        "validate": "createUserSchema"
      },
      {
        "method": "POST",
        "path": "/login",
        "handler": "authController.loginUser",
        "auth": "Public",
        "validate": "loginUserSchema"
      },
      {
        "method": "POST",
        "path": "/admin/login",
        "handler": "authController.loginUser",
        "auth": "Public",
        "validate": "loginUserSchema"
      },
      {
        "method": "POST",
        "path": "/admin/forgot-password",
        "handler": "authController.sendOtp",
        "auth": "Public"
      },
      {
        "method": "POST",
        "path": "/admin/verify-reset-otp",
        "handler": "authController.verifyOtp",
        "auth": "Public"
      },
      {
        "method": "POST",
        "path": "/admin/reset-password",
        "handler": "authController.setNewPassword",
        "auth": "Public"
      },
      {
        "method": "POST",
        "path": "/admin/change-password",
        "handler": "authController.changePassword",
        "auth": "Authenticated",
        "validate": "changePasswordSchema"
      },
      {
        "method": "POST",
        "path": "/check-user",
        "handler": "authController.checkUser",
        "auth": "Public"
      },
      {
        "method": "POST",
        "path": "/change-password",
        "handler": "authController.changePassword",
        "auth": "Authenticated",
        "validate": "changePasswordSchema"
      },
      {
        "method": "POST",
        "path": "/send-otp",
        "handler": "authController.sendOtp",
        "auth": "Public"
      },
      {
        "method": "POST",
        "path": "/verify-otp",
        "handler": "authController.verifyOtp",
        "auth": "Public"
      },
      {
        "method": "POST",
        "path": "/set-new-password",
        "handler": "authController.setNewPassword",
        "auth": "Public"
      },
      {
        "method": "POST",
        "path": "/refresh-token",
        "handler": "authController.refreshToken",
        "auth": "Public"
      },
      {
        "method": "POST",
        "path": "/logout",
        "handler": "authController.logout",
        "auth": "Public"
      }
    ]
  },
  {
    "module": "User",
    "basePath": "/users",
    "routes": [
      {
        "method": "POST",
        "path": "/",
        "handler": "userController.createUser",
        "auth": "Authenticated",
        "roles": [
          "Admin"
        ],
        "validate": "CreateUserSchema"
      },
      {
        "method": "GET",
        "path": "/",
        "handler": "userController.getAllUsers",
        "auth": "Authenticated"
      },
      {
        "method": "GET",
        "path": "/riders",
        "handler": "userController.getRiders",
        "auth": "Authenticated",
        "roles": [
          "Admin"
        ]
      },
      {
        "method": "GET",
        "path": "/me",
        "handler": "userController.getMyProfile",
        "auth": "Authenticated"
      },
      {
        "method": "PATCH",
        "path": "/me",
        "handler": "userController.updateMyProfile",
        "auth": "Authenticated",
        "upload": "profileImage (single)"
      },
      {
        "method": "PATCH",
        "path": "/me/location",
        "handler": "userController.updateLocation",
        "auth": "Authenticated"
      },
      {
        "method": "PATCH",
        "path": "/me/documents",
        "handler": "userController.updateDriverDocuments",
        "auth": "Authenticated",
        "upload": "emaratesId (1), drivingLicense (1), vehicleRegistration (1)"
      },
      {
        "method": "GET",
        "path": "/me/addresses",
        "handler": "userController.getAddresses",
        "auth": "Authenticated"
      },
      {
        "method": "POST",
        "path": "/me/addresses",
        "handler": "userController.addAddress",
        "auth": "Authenticated"
      },
      {
        "method": "PATCH",
        "path": "/me/addresses/:addressId",
        "handler": "userController.updateAddress",
        "auth": "Authenticated"
      },
      {
        "method": "DELETE",
        "path": "/me/addresses/:addressId",
        "handler": "userController.deleteAddress",
        "auth": "Authenticated"
      },
      {
        "method": "GET",
        "path": "/:id",
        "handler": "userController.getUserById",
        "auth": "Authenticated"
      },
      {
        "method": "PATCH",
        "path": "/:id",
        "handler": "userController.updateUser",
        "auth": "Authenticated",
        "roles": [
          "Admin"
        ],
        "upload": "profileImage (single)"
      },
      {
        "method": "DELETE",
        "path": "/:id",
        "handler": "userController.deleteUser",
        "auth": "Authenticated",
        "roles": [
          "Admin"
        ]
      }
    ]
  },
